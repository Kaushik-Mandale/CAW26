{
  "name": "campus-achievement-wallet",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A Web3 dApp for HackWithMumbai 3.0 — Gasless NFT Achievement Certificates using UGF on Base Sepolia",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "compile": "hardhat --config hardhat.config.cjs compile",
    "deploy:baseSepolia": "hardhat --config hardhat.config.cjs run scripts/deploy.cjs --network baseSepolia"
  },
  "dependencies": {
    "@tychilabs/react-ugf": "^1.0.8",
