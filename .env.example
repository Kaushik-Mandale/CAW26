# ============================================================
#  Campus Achievement Wallet — Environment Variables
#  Copy this file to .env.local and fill in your values
# ============================================================

# ---- Firebase Configuration ----
# Get these from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ---- Smart Contract (Base Sepolia) ----
# After running: npm run deploy:baseSepolia
# Paste the deployed contract address here
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ---- Network Config ----
VITE_CHAIN_ID=84532
VITE_NETWORK_NAME=Base Sepolia
VITE_RPC_URL=https://sepolia.base.org
VITE_EXPLORER_URL=https://sepolia.basescan.org

# ---- Hardhat Deployment (NOT exposed to frontend) ----
# Add your deployer wallet private key here (keep secret!)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=your_basescan_api_key_optional
